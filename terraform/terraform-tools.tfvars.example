aws_region   = "ap-southeast-1"
cluster_name = "devsecops-tools"
use_eks      = false

control_plane_instance_type = "t3.small"
control_plane_count         = 1

worker_instance_type = "t3.large"
worker_count         = 3

admin_username  = "ubuntu"
public_key_path = "~/.ssh/id_ed25519.pub"

# Your local IP — run: curl ifconfig.me
allowed_ssh_cidr = "YOUR_IP/32"

vpc_cidr            = "10.0.0.0/16"
public_subnet_cidr  = "10.0.10.0/24"
private_subnet_cidr = "10.0.20.0/24"

k8s_version = "1.29"

# Create KMS key first: aws kms create-key --description "vault-unseal" --region ap-southeast-1
vault_kms_key_arn  = "arn:aws:kms:ap-southeast-1:YOUR_ACCOUNT_ID:key/YOUR_KEY_ID"
enable_vpc_peering = false
