# secrets.list — Danh sách secrets cần lưu vào AWS SSM
# Mỗi dòng = 1 env var name
# - push-secrets.sh : đẩy từ .env.secret lên SSM
# - load-secrets.sh : kéo từ SSM xuống shell khi deploy

# SSH keys (base64-encoded)
SSH_PRIVATE_KEY
SSH_PUBLIC_KEY

# Service credentials
GRAFANA_ADMIN_PASSWORD
JENKINS_ADMIN_PASSWORD
HARBOR_ADMIN_PASSWORD
SONAR_DB_PASSWORD
ARGOCD_ADMIN_PASSWORD
ARGOCD_REDIS_PASSWORD
