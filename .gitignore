# Ignore everything
/*

# Allow app/src, jenkins, k8s, terraform, connect.sh
!app/
app/*
!app/src/
!jenkins/
!jenkins/Jenkinsfile
!k8s/
!connect.sh
!terraform/
!README.md

# Allow all files under app/src
app/src/**

# Terraform
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*
override.tf
override.tf.json
*_override.tf
*_override.tf.json
*.tfvars.json
secrets.tfvars

# Kubespray
kubespray/.venv/
kubespray/kubespray-src/
