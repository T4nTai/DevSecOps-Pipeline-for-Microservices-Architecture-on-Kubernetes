# Ignore everything at root, then allowlist what should be committed
/*

# Core project files
!README.md
!connect.sh
!secrets.list
!docker-compose.yml

# Source directories
!scripts/
!k8s/
!terraform/
!jenkins/
!app/
app/*
!app/src/
app/src/**

# Terraform — never commit state or local overrides
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*_override.tf
*_override.tf.json
secrets.tfvars
*.tfvars.json

# Kubespray
kubespray/.venv/
kubespray/kubespray-src/

# Runtime state — never commit
.deploy-state.env
.env
.env.secret
.kubeconfig
