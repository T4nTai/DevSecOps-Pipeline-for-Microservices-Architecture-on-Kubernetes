# Ignore everything at root, then allowlist what should be committed
/*

# Core project files
!README.md
!connect.sh
!secrets.list
!docker-compose.yml

# Source directories
!scripts/
!k8s/
!infra/
!platform/
!tools/
!apps/
!docs/
!jenkins/
!app/
app/*
!app/src/
!app/src/**

# Terraform — never commit state or local overrides
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*_override.tf
*_override.tf.json
secrets.tfvars
*.tfvars.json

# Terraform — runtime-generated and environment-specific (contain real IPs, AWS account IDs)
infra/inventory.ini
infra/**/terraform.tfvars
infra/**/*-tools.tfvars
infra/**/*-apps.tfvars

# Kubespray
kubespray/.venv/
kubespray/kubespray-src/
platform/kubespray/.venv/
platform/kubespray/kubespray-src/

# Runtime state — never commit
.deploy-state.env
.env
.env.secret
.kubeconfig

# App build artifacts
app/src/**/.gradle/
app/src/**/bin/
app/src/**/build/
app/src/**/node_modules/
app/src/**/__pycache__/
app/src/**/*.class
