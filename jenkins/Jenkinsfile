pipeline {
    agent {
        kubernetes {
            defaultContainer 'builder'
            yaml """
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins
  containers:
    - name: builder
      image: golang:1.26-alpine
      command: ["sleep", "infinity"]
      resources:
        requests:
          cpu: "100m"
          memory: "512Mi"
        limits:
          cpu: "500m"
          memory: "1Gi"
      env:
        - name: GOPATH
          value: /go
        - name: CGO_ENABLED
          value: "0"

    - name: sonar-scanner
      image: sonarsource/sonar-scanner-cli:latest
      command: ["sleep", "infinity"]
      resources:
        requests:
          cpu: "100m"
          memory: "256Mi"
        limits:
          cpu: "300m"
          memory: "512Mi"

    - name: checkov
      image: bridgecrew/checkov:latest
      command: ["sleep", "infinity"]
      resources:
        requests:
          cpu: "50m"
          memory: "128Mi"
        limits:
          cpu: "200m"
          memory: "256Mi"

    - name: kaniko
      image: gcr.io/kaniko-project/executor:debug
      command: ["sleep", "infinity"]
      resources:
        requests:
          cpu: "200m"
          memory: "1Gi"
        limits:
          cpu: "1000m"
          memory: "4Gi"
      volumeMounts:
        - name: kaniko-secret
          mountPath: /kaniko/.docker

    - name: kubectl
      image: bitnami/kubectl:latest
      command: ["sleep", "infinity"]
      resources:
        requests:
          cpu: "50m"
          memory: "64Mi"

  volumes:
    - name: kaniko-secret
      secret:
        secretName: harbor-credentials
        items:
          - key: .dockerconfigjson
            path: config.json
"""
        }
    }

    environment {
        // HARBOR_REGISTRY, HARBOR_PROJECT, SONARQUBE_URL
        // set in Manage Jenkins → System → Global Properties → Environment Variables
        IMAGE_NAME        = "frontend"
        IMAGE_TAG         = "${BUILD_NUMBER}"
        FULL_IMAGE        = "${HARBOR_REGISTRY}/${HARBOR_PROJECT}/${IMAGE_NAME}:${IMAGE_TAG}"
        SONAR_PROJECT_KEY = "frontend"
        APP_DIR           = "app/src/frontend"
        VAULT_ADDR        = "http://vault.vault.svc.cluster.local:8200"
        VAULT_TOKEN       = "root"  // dev mode only — use AppRole in production
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Checkov — IaC Scan') {
            steps {
                container('checkov') {
                    sh '''
                        echo "==> Running Checkov IaC scan on Terraform..."
                        checkov -d terraform/ \
                          --output cli \
                          --soft-fail \
                          --quiet
                        echo "==> Checkov scan complete"
                    '''
                }
            }
        }

        stage('Build') {
            steps {
                container('builder') {
                    dir("${APP_DIR}") {
                        sh '''
                            echo "==> Building frontend..."
                            go mod download
                            go build -ldflags="-s -w" -o /tmp/frontend .
                            echo "==> Build successful"
                        '''
                    }
                }
            }
        }

        stage('Unit Tests') {
            steps {
                container('builder') {
                    dir("${APP_DIR}") {
                        sh 'go test ./... -v -coverprofile=coverage.out'
                    }
                }
            }
        }

        stage('SonarQube Analysis & Quality Gate') {
            steps {
                container('sonar-scanner') {
                    withSonarQubeEnv('SonarQube') {
                        withCredentials([string(credentialsId: 'sonarqube-token', variable: 'SONAR_TOKEN')]) {
                            sh """
                                sonar-scanner \
                                  -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                                  -Dsonar.sources=${APP_DIR} \
                                  -Dsonar.host.url=${SONARQUBE_URL} \
                                  -Dsonar.login=\${SONAR_TOKEN} \
                                  -Dsonar.go.coverage.reportPaths=${APP_DIR}/coverage.out
                            """
                        }
                    }
                }
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build & Push Image') {
            steps {
                container('kaniko') {
                    sh """
                        echo "==> Building and pushing image to Harbor..."
                        /kaniko/executor \
                          --context="${WORKSPACE}/${APP_DIR}" \
                          --dockerfile="${WORKSPACE}/${APP_DIR}/Dockerfile" \
                          --destination="${FULL_IMAGE}" \
                          --insecure \
                          --skip-tls-verify \
                          --cache=true
                        echo "==> Image pushed: ${FULL_IMAGE}"
                    """
                }
            }
        }

        stage('Update Manifest') {
            steps {
                container('builder') {
                    withCredentials([usernamePassword(
                        credentialsId: 'git-credentials',
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_TOKEN'
                    )]) {
                        sh """
                            echo "==> Updating image tag in k8s manifest..."

                            # Update the image line in the deployment manifest
                            sed -i 's|image: .*frontend:.*|image: ${FULL_IMAGE}|' \
                              k8s/apps/frontend/deployment.yaml

                            # Configure git
                            git config user.email "jenkins@ci.local"
                            git config user.name "Jenkins"

                            # Commit and push — ArgoCD will pick up the change
                            git add k8s/apps/frontend/deployment.yaml
                            git commit -m "ci: update frontend image to ${IMAGE_TAG}"
                            git push https://\${GIT_USER}:\${GIT_TOKEN}@\$(git remote get-url origin | sed 's|https://||') HEAD:main
                        """
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline passed. Image: ${FULL_IMAGE}"
        }
        failure {
            echo "Pipeline failed."
        }
    }
}
