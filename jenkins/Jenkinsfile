pipeline {
    agent {
        kubernetes {
            defaultContainer 'builder'
            yaml """
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins
  containers:
    - name: builder
      image: golang:1.26-alpine
      imagePullPolicy: IfNotPresent
      command: ["sleep", "infinity"]
      resources:
        requests:
          cpu: "50m"
          memory: "256Mi"
        limits:
          cpu: "500m"
          memory: "1Gi"
      env:
        - name: GOPATH
          value: /go
        - name: CGO_ENABLED
          value: "0"

    - name: sonar-scanner
      image: sonarsource/sonar-scanner-cli:latest
      imagePullPolicy: IfNotPresent
      command: ["sleep", "infinity"]
      resources:
        requests:
          cpu: "50m"
          memory: "256Mi"
        limits:
          cpu: "300m"
          memory: "512Mi"

    - name: checkov
      image: bridgecrew/checkov:latest
      imagePullPolicy: IfNotPresent
      command: ["sleep", "infinity"]
      resources:
        requests:
          cpu: "25m"
          memory: "128Mi"
        limits:
          cpu: "200m"
          memory: "256Mi"

    - name: kaniko
      image: gcr.io/kaniko-project/executor:debug
      imagePullPolicy: IfNotPresent
      command: ["sleep", "infinity"]
      resources:
        requests:
          cpu: "100m"
          memory: "512Mi"
        limits:
          cpu: "1000m"
          memory: "2Gi"
      volumeMounts:
        - name: kaniko-secret
          mountPath: /kaniko/.docker

    - name: trivy
      image: aquasec/trivy:0.61.0
      imagePullPolicy: IfNotPresent
      command: ["sleep", "infinity"]
      resources:
        requests:
          cpu: "50m"
          memory: "256Mi"
        limits:
          cpu: "500m"
          memory: "1Gi"
      volumeMounts:
        - name: kaniko-secret
          mountPath: /root/.docker

    - name: yq
      image: mikefarah/yq:4.44.3
      imagePullPolicy: IfNotPresent
      command: ["sleep", "infinity"]
      resources:
        requests:
          cpu: "25m"
          memory: "64Mi"
        limits:
          cpu: "100m"
          memory: "128Mi"

    - name: manifest-updater
      image: alpine/git:2.47.2
      imagePullPolicy: IfNotPresent
      command: ["sleep", "infinity"]
      resources:
        requests:
          cpu: "25m"
          memory: "64Mi"
        limits:
          cpu: "100m"
          memory: "128Mi"

  volumes:
    - name: kaniko-secret
      secret:
        secretName: harbor-credentials
        items:
          - key: .dockerconfigjson
            path: config.json
"""
        }
    }

    environment {
        IMAGE_NAME        = "frontend"
        IMAGE_TAG         = "${BUILD_NUMBER}"
        SONAR_PROJECT_KEY = "frontend"
        APP_DIR           = "app/src/frontend"
        HARBOR_PROJECT    = "library"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Test & IaC Scan') {
            parallel {
                stage('Unit Tests') {
                    steps {
                        container('builder') {
                            dir("${APP_DIR}") {
                                sh 'go test ./... -v -coverprofile=coverage.out'
                            }
                        }
                    }
                }
                stage('Checkov — IaC Scan') {
                    steps {
                        container('checkov') {
                            sh '''
                                echo "==> Running Checkov IaC scan on Terraform..."
                                checkov -d terraform/ \
                                  --output cli \
                                  --soft-fail \
                                  --quiet
                                echo "==> Checkov scan complete"
                            '''
                        }
                    }
                }
            }
        }

        stage('Build') {
            steps {
                container('builder') {
                    dir("${APP_DIR}") {
                        sh '''
                            echo "==> Building frontend..."
                            go build -ldflags="-s -w" -o /tmp/frontend .
                            echo "==> Build successful"
                        '''
                    }
                }
            }
        }

        stage('SonarQube Analysis & Quality Gate') {
            steps {
                withVault(
                    configuration: [
                        vaultUrl: 'http://vault.vault.svc.cluster.local:8200',
                        vaultCredentialId: 'vault-approle',
                        engineVersion: 2
                    ],
                    vaultSecrets: [[
                        path: 'secret/sonarqube',
                        secretValues: [
                            [envVar: 'SONAR_TOKEN', vaultKey: 'token']
                        ]
                    ]]
                ) {
                    container('sonar-scanner') {
                        withSonarQubeEnv('SonarQube') {
                            sh '''
                                sonar-scanner \
                                  -Dsonar.projectKey=$SONAR_PROJECT_KEY \
                                  -Dsonar.sources=$APP_DIR \
                                  -Dsonar.token=$SONAR_TOKEN \
                                  -Dsonar.scm.disabled=true \
                                  -Dsonar.go.coverage.reportPaths=$APP_DIR/coverage.out
                            '''
                        }
                    }
                    timeout(time: 15, unit: 'MINUTES') {
                        waitForQualityGate abortPipeline: false
                    }
                }
            }
        }

        stage('Build & Push Image') {
            steps {
                withVault(
                    configuration: [
                        vaultUrl: 'http://vault.vault.svc.cluster.local:8200',
                        vaultCredentialId: 'vault-approle',
                        engineVersion: 2
                    ],
                    vaultSecrets: [[
                        path: 'secret/harbor',
                        secretValues: [
                            [envVar: 'HARBOR_REGISTRY', vaultKey: 'registry']
                        ]
                    ]]
                ) {
                    script {
                        env.FULL_IMAGE = "${env.HARBOR_REGISTRY}/${env.HARBOR_PROJECT}/${env.IMAGE_NAME}:${env.IMAGE_TAG}"
                    }
                    container('kaniko') {
                        sh '''
                            echo "==> Building and pushing image to Harbor..."
                            /kaniko/executor \
                              --context="$WORKSPACE/$APP_DIR" \
                              --dockerfile="$WORKSPACE/$APP_DIR/Dockerfile" \
                              --destination="$FULL_IMAGE" \
                              --insecure \
                              --skip-tls-verify \
                              --cache=true
                            echo "==> Image pushed: $FULL_IMAGE"
                        '''
                    }
                }
            }
        }

        stage('Trivy — Image Scan') {
            steps {
                container('trivy') {
                    sh '''
                        echo "==> Scanning image with Trivy..."
                        trivy image \
                          --exit-code 0 \
                          --severity HIGH,CRITICAL \
                          --no-progress \
                          --insecure \
                          $FULL_IMAGE
                        echo "==> Trivy scan complete"
                    '''
                }
            }
        }

        stage('Update Manifest') {
            steps {
                withVault(
                    configuration: [
                        vaultUrl: 'http://vault.vault.svc.cluster.local:8200',
                        vaultCredentialId: 'vault-approle',
                        engineVersion: 2
                    ],
                    vaultSecrets: [[
                        path: 'secret/git',
                        secretValues: [
                            [envVar: 'GIT_USER',  vaultKey: 'username'],
                            [envVar: 'GIT_TOKEN', vaultKey: 'token']
                        ]
                    ]]
                ) {
                    container('yq') {
                        sh """
                            echo "==> Updating image tag in k8s manifest..."
                            yq e '.spec.template.spec.containers[0].image = "${FULL_IMAGE}"' \
                              -i k8s/apps/frontend/deployment.yaml
                        """
                    }
                    container('manifest-updater') {
                        sh """
                            git config --global --add safe.directory "${WORKSPACE}"
                            git config user.email "jenkins@ci.local"
                            git config user.name "Jenkins"

                            git add k8s/apps/frontend/deployment.yaml
                            git commit -m "ci: update frontend image to ${IMAGE_TAG}"
                            git push https://\${GIT_USER}:\${GIT_TOKEN}@\$(git remote get-url origin | sed 's|https://||') HEAD:main
                        """
                    }
                }
            }
        }
    }

    post {
        success {
            withCredentials([string(credentialsId: 'slack-webhook-url', variable: 'SLACK_URL')]) {
                sh """
                    curl -s -X POST \$SLACK_URL \
                      -H 'Content-type: application/json' \
                      --data '{"text":" Build #${BUILD_NUMBER} passed. Image: ${FULL_IMAGE} — ${BUILD_URL}"}'
                """
            }
        }
        failure {
            withCredentials([string(credentialsId: 'slack-webhook-url', variable: 'SLACK_URL')]) {
                sh """
                    curl -s -X POST \$SLACK_URL \
                      -H 'Content-type: application/json' \
                      --data '{"text":" Build #${BUILD_NUMBER} failed — ${BUILD_URL}"}'
                """
            }
        }
    }
}
